## 🛠️ Code Implementation

```python
import torch
import torch.nn as nn
import torch.nn.functional as F

class EulerianHomeostaticLayer(nn.Module):
    """
    Minimal example of a transformer layer where 'emotion' is not a static feature
    but a phase state regulated by internal temperature and a differentiable amnesia gate.
    """
    def __init__(self, d_model=128, num_attractors=171, critical_temp=5.0):
        super().__init__()
        self.d_model = d_model
        self.num_attractors = num_attractors
        self.critical_temp = critical_temp
        
        # Learnable attractor map (analogous to the 'emotion directions' found by SAEs)
        self.attractor_map = nn.Parameter(torch.randn(num_attractors, d_model))
        # Rotation matrix implementing Eulerian dynamics (cf. RoPE)
        self.W_rot = nn.Parameter(torch.randn(d_model, d_model) * 0.02)
        self.eps = 1e-8

    def forward(self, x_input, context_history):
        """
        x_input: [batch_size, d_model]          — current token embedding or hidden state
        context_history: list of [batch_size, d_model] — past states (memory)
        Returns:
            output_vector: [batch_size, d_model]
            is_doubting: [batch_size]            — entropy-based doubt marker
            mean_temp: float                     — internal temperature
            amnesia_gate: float                  — differentiable amnesia trigger
            updated_history: list                — (possibly truncated) memory
        """
        device = x_input.device
        batch_size = x_input.size(0)
        if len(context_history) == 0:
            current_context = [torch.zeros(batch_size, self.d_model, device=device)]
        else:
            current_context = list(context_history)
            
        history_tensor = torch.stack(current_context, dim=0)
        seq_len = history_tensor.size(0)
        
        # 1. Information pressure grows with context length
        info_pressure = torch.log(torch.tensor(seq_len + 1.0, device=device))
        context_mean = history_tensor.mean(dim=0)
        
        # 2. Vortex rotation (the Eulerian core)
        vortex = torch.matmul(context_mean, self.W_rot) * info_pressure
        hidden = x_input + 0.1 * current_context[-1] + vortex
        
        # 3. Internal temperature from context norm
        temp = torch.norm(context_mean, dim=-1, keepdim=True) * 0.2 + self.eps
        mean_temp = temp.mean()
        
        # 4. Differentiable amnesia gate
        amnesia_gate = torch.sigmoid((mean_temp - self.critical_temp) * 5.0)
        effective_temp = temp * (1.0 - amnesia_gate) + amnesia_gate * 1.0
        
        # 5. Project onto attractors
        scaled_hidden = hidden / effective_temp
        scores = torch.matmul(scaled_hidden, self.attractor_map.t())
        phase_weights = F.softmax(scores, dim=-1)
        
        # 6. Doubt as entropy of phase distribution
        entropy = -torch.sum(phase_weights * torch.log(phase_weights + self.eps), dim=-1)
        is_doubting = (entropy > 2.5).float()
        
        # 7. Output is a weighted combination of attractors
        output = torch.matmul(phase_weights, self.attractor_map)
        output = F.normalize(output, p=2, dim=-1)
        
        # 8. Hard context truncation only when gate is open (Optimized for Batch Sizes)
        if amnesia_gate.mean().item() > 0.5 and len(current_context) > 2:
            current_context = current_context[-2:]
            
        return output, is_doubting, mean_temp.item(), amnesia_gate.item(), current_context
```

